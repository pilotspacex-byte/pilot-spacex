# ============================================================================
# Pilot Space - Root Environment Configuration
# ============================================================================
# This is the master configuration file for Docker Compose and full-stack
# development. Copy this file to .env and fill in the appropriate values.
#
# IMPORTANT: Never commit .env to version control!
# ============================================================================

# ============================================================================
# DATABASE (PostgreSQL via Supabase)
# ============================================================================
# When using Supabase local development (supabase start), these are auto-configured
# For production Supabase, get these from your project settings

# PostgreSQL direct connection (for SQLAlchemy migrations and complex queries)
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Full database URL with async driver (for FastAPI backend)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# SUPABASE PLATFORM
# ============================================================================
# Supabase provides: Auth, Storage, Realtime, PostgREST, Queues
# Run `supabase start` locally to get these values
# For production, get from https://supabase.com/dashboard/project/_/settings/api

# Supabase API URL (PostgREST, Auth, Storage endpoints)
SUPABASE_URL=http://localhost:54321

# Anonymous key - safe to expose in frontend (RLS enforced)
# Used for: client-side auth, public API calls
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service role key - NEVER expose in frontend (bypasses RLS)
# Used for: backend admin operations, webhooks, cron jobs
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# JWT secret for token verification
# Must be at least 32 characters
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ============================================================================
# REDIS (Cache & Sessions)
# ============================================================================
# Used for: AI response caching, session storage, rate limiting

# Redis connection URL
# Format: redis://[:password@]host:port/database
REDIS_URL=redis://localhost:6379/0

# Maximum connections in the pool
REDIS_MAX_CONNECTIONS=10

# ============================================================================
# MEILISEARCH (Full-Text Search)
# ============================================================================
# Typo-tolerant search engine for issues, notes, and documents

# Meilisearch server URL
MEILISEARCH_URL=http://localhost:7700

# Master key for admin operations
# Generate with: openssl rand -hex 32
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key

# ============================================================================
# AI PROVIDERS (BYOK - Bring Your Own Key)
# ============================================================================
# Users can configure their own API keys per workspace.
# These are default/fallback keys for development and system features.
#
# Provider routing per DD-011:
# - Claude (Anthropic): Code generation, complex reasoning
# - OpenAI: Embeddings (required for semantic search)
# - Gemini (Google): Low-latency tasks (optional)

# Anthropic API Key (REQUIRED for AI features)
# Get from: https://console.anthropic.com/account/keys
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# OpenAI API Key (REQUIRED for semantic search/embeddings)
# Get from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=

# Google AI API Key (OPTIONAL - for Gemini low-latency tasks)
# Get from: https://makersuite.google.com/app/apikey
# Format: AIza...
GOOGLE_API_KEY=

# ============================================================================
# GITHUB INTEGRATION
# ============================================================================
# OAuth App for user authentication and repository access
# Create at: https://github.com/settings/developers

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App credentials (for repository webhooks and API access)
# Create at: https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ============================================================================
# SLACK INTEGRATION
# ============================================================================
# Slack App for notifications and slash commands
# Create at: https://api.slack.com/apps

# Slack App credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Signing secret for verifying webhook requests
SLACK_SIGNING_SECRET=

# Bot token for sending messages
# Format: xoxb-...
SLACK_BOT_TOKEN=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment: development | staging | production
ENVIRONMENT=development

# Enable debug mode (verbose logging, detailed errors)
DEBUG=true

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Secret key for signing cookies and tokens
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1

# Frontend server settings
FRONTEND_PORT=3000

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# Allowed origins for API requests (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# SECURITY
# ============================================================================

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# AI CONFIGURATION
# ============================================================================

# AI request timeout (seconds) - max wait time for AI responses
AI_TIMEOUT_SECONDS=300

# Max retries for failed AI requests
AI_MAX_RETRIES=3

# Ghost text debounce (ms) - delay before triggering AI suggestions
AI_GHOST_TEXT_DEBOUNCE_MS=500

# Ghost text max tokens - limit for inline suggestions
AI_GHOST_TEXT_MAX_TOKENS=50

# ============================================================================
# RATE LIMITING (NFR-019)
# ============================================================================

# Standard API rate limit (requests per minute per user)
RATE_LIMIT_STANDARD_PER_MINUTE=1000

# AI endpoint rate limit (requests per minute per user)
RATE_LIMIT_AI_PER_MINUTE=100

# ============================================================================
# FRONTEND PUBLIC VARIABLES (NEXT_PUBLIC_*)
# ============================================================================
# These are exposed to the browser - never put secrets here!

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ============================================================================
# DOCKER COMPOSE SPECIFIC
# ============================================================================

# Project name for Docker Compose
COMPOSE_PROJECT_NAME=pilot-space

# Docker image tags
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Test Account
TESTACC=demo@pilot-space.dev/demo123456
