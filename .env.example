# =============================================================================
# Pilot Space - Root Environment Configuration
# =============================================================================
# Copy this file to .env and configure before running Docker Compose.
#
#   cp .env.example .env
#   # Edit .env: fill in all CHANGE_ME values
#   docker compose up -d
#   docker compose exec backend alembic upgrade head
#
# NEVER commit .env to version control.
# =============================================================================

# === Database ===
# PostgreSQL credentials used by the postgres service and all services
# that connect to it (backend, supabase-auth).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=pilot_space
POSTGRES_PORT=5432

# === Redis ===
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# === Supabase Auth ===
# JWT_SECRET: shared by postgres, supabase-auth, and backend.
# Must be at least 32 characters.  Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_jwt_secret

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY=3600

# Supabase anon key (JWT signed with JWT_SECRET, role=anon).
# For local dev, generate with supabase CLI (supabase status) or use a known
# test token.  In production, generate per the self-hosting guide:
# https://supabase.com/docs/guides/self-hosting#api-keys
SUPABASE_ANON_KEY=CHANGE_ME_supabase_anon_key

# Supabase service role key (JWT, role=service_role).
# KEEP SECRET — grants full DB access bypassing RLS.
SUPABASE_SERVICE_KEY=CHANGE_ME_supabase_service_role_key

# Public URL for the Kong gateway (used by browser clients).
# Default matches the SUPABASE_KONG_PORT below.
SUPABASE_URL=http://localhost:18000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:18000

# Kong port mapping (host:container)
SUPABASE_KONG_PORT=18000
SUPABASE_KONG_HTTPS_PORT=18443

# GoTrue (supabase-auth) internal port
GOTRUE_PORT=9999

# Frontend URL for OAuth redirects and email verification links
GOTRUE_SITE_URL=http://localhost:3000

# Comma-separated list of additional allowed redirect URLs (leave blank for defaults)
GOTRUE_URI_ALLOW_LIST=

# Disable public signup (invite-only mode). Set true for production.
GOTRUE_DISABLE_SIGNUP=false

# Email / phone authentication
GOTRUE_ENABLE_EMAIL_SIGNUP=true
GOTRUE_ENABLE_PHONE_AUTH=false

# OAuth providers — disabled by default
GOTRUE_ENABLE_GITHUB_AUTH=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOTRUE_ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Multi-factor authentication
GOTRUE_ENABLE_MFA=true

# SMTP — required for email verification, password reset, and magic links.
# Leave blank for local dev (GoTrue logs emails to stdout instead).
# For production: use SendGrid, AWS SES, Postmark, etc.
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=admin@pilot-space.local
GOTRUE_SMTP_SENDER_NAME=Pilot Space

# Auto-confirm emails (DEVELOPMENT ONLY — never use in production)
GOTRUE_MAILER_AUTOCONFIRM=false

# === Application ===
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# === Backend ===
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_BUILD_TARGET=production

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS: comma-separated list of allowed origins for the FastAPI backend
CORS_ORIGINS=http://localhost:3000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_STANDARD_PER_MINUTE=1000
RATE_LIMIT_AI_PER_MINUTE=100

# Database pool sizing
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
REDIS_MAX_CONNECTIONS=20

# Super admin token — leave blank to disable the /admin/* endpoints
PILOT_SPACE_SUPER_ADMIN_TOKEN=

# === Frontend ===
FRONTEND_PORT=3000
FRONTEND_BUILD_TARGET=production
NODE_ENV=production

# Public API URL (browser calls go here)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Feature flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_REALTIME=true

# Supabase Studio (--profile dev only)
STUDIO_PORT=54323
STUDIO_DEFAULT_ORG=Pilot Space
STUDIO_DEFAULT_PROJECT=pilot-space

# === AI / BYOK ===
# Pilot Space is Bring Your Own Key — no AI cost pass-through.
# Users configure keys per workspace in the Settings UI.
# The values below are development fallbacks only.
# In production, leave blank unless you want a platform-level fallback key.
#
# Get your Anthropic key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get your OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get your Google AI key: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# AI behavior tuning
AI_TIMEOUT_SECONDS=300
AI_MAX_RETRIES=3
AI_GHOST_TEXT_DEBOUNCE_MS=500
AI_GHOST_TEXT_MAX_TOKENS=50

# === Meilisearch ===
# Master key for Meilisearch authentication.
# Generate with: openssl rand -hex 16
MEILI_MASTER_KEY=CHANGE_ME_meilisearch_master_key
MEILISEARCH_PORT=7700
MEILI_ENV=development
MEILI_LOG_LEVEL=INFO
MEILI_MAX_INDEXING_MEMORY=512Mb
MEILI_MAX_INDEXING_THREADS=2

# === Images (CI override) ===
# Set in CI to deploy a specific build without rebuilding from source.
# Example: BACKEND_IMAGE=ghcr.io/org/backend:abc1234 docker compose up -d
BACKEND_IMAGE=pilot-space/backend:latest
FRONTEND_IMAGE=pilot-space/frontend:latest
