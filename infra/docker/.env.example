# =============================================================================
# Pilot Space MVP - Docker Compose Environment Configuration
# =============================================================================
# Copy this file to .env and configure your values.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Pilot Space
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# REDIS CACHE
# =============================================================================
# Image: redis:7-alpine

REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# MEILISEARCH SEARCH ENGINE
# =============================================================================
# Image: getmeili/meilisearch:v1.6

MEILISEARCH_PORT=7700
MEILISEARCH_API_KEY=meilisearch-dev-key
MEILI_ENV=development
MEILI_LOG_LEVEL=INFO

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

SUPABASE_URL=http://localhost:8000
SUPABASE_STUDIO_PORT=54323
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24ifQ.625_WdcF3KHqz5amU0x2X5WWHP-OEs_4qj0ssLNHzTs
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSJ9.vI9obAHOGyVVKa3pD--kJlyxp-Z2zV9UUMAhKpNLAcU
SUPABASE_JWT_SECRET=QPWIF+VM4wF3j/6t4QsxfBVt2J+ZcRbUMVbogOOF

# =============================================================================
# MIGRATION CONFIGURATION
# =============================================================================

RUN_SEED=true
MIGRATION_SUPABASE_URL=http://host.docker.internal:8000

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_BUILD_TARGET=development

DATABASE_URL=postgresql+asyncpg://postgres.your-tenant-id:your-super-secret-password@localhost:5432/postgres

# Security settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_STANDARD_PER_MINUTE=1000
RATE_LIMIT_AI_PER_MINUTE=100

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

FRONTEND_PORT=3000
FRONTEND_BUILD_TARGET=development
NODE_ENV=development

# Public API URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Feature flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_REALTIME=true

# =============================================================================
# AI PROVIDERS (BYOK - Bring Your Own Key)
# =============================================================================
# These keys are optional at the infrastructure level.
# Users configure their own keys per workspace in the application.
# For development/testing, you can provide keys here.

# Anthropic (REQUIRED for AI features)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (REQUIRED for embeddings/search)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI (OPTIONAL - for latency-sensitive features)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# AI behavior settings
AI_TIMEOUT_SECONDS=300
AI_MAX_RETRIES=3
AI_GHOST_TEXT_DEBOUNCE_MS=500
AI_GHOST_TEXT_MAX_TOKENS=50

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify for production deployments:
#
# APP_ENV=production
# DEBUG=false
# LOG_LEVEL=WARNING
#
# BACKEND_BUILD_TARGET=production
# BACKEND_WORKERS=4
#
# FRONTEND_BUILD_TARGET=production
# NODE_ENV=production
#
# # Use strong passwords in production
# POSTGRES_PASSWORD=<strong-random-password>
# MEILISEARCH_API_KEY=<strong-random-key>
