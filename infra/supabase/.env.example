# =============================================================================
# Pilot Space - Self-Hosted Supabase Environment Configuration
# =============================================================================
# Copy this file to .env and configure your values.
#
# SECURITY NOTICE: NEVER commit .env to version control.
#
# For production deployments:
# 1. Generate all secrets using secure random generators
# 2. Use a secrets manager (Vault, AWS Secrets Manager, etc.)
# 3. Rotate keys regularly
#
# Usage:
#   cp .env.example .env
#   # Generate secure secrets (see README.md for script)
#   # Edit .env with your values
#   docker compose up -d
# =============================================================================

# =============================================================================
# SECRETS - MUST BE CHANGED FOR PRODUCTION
# =============================================================================
# IMPORTANT: Generate these using the provided script or:
#   openssl rand -hex 32
#
# These are PLACEHOLDER values - DO NOT use in production!

# JWT Secret - Used for all Supabase JWT tokens (min 32 chars)
# CRITICAL: Must be the same across all services
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Anon Key - Public key for anonymous/unauthenticated access
# Generate using: https://supabase.com/docs/guides/self-hosting#api-keys
# Or use the generate-keys.sh script
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Service Role Key - Private key with full database access (KEEP SECRET)
# Generate using: https://supabase.com/docs/guides/self-hosting#api-keys
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Realtime Secret - Used for Phoenix framework
# Generate using: openssl rand -base64 48
REALTIME_SECRET_KEY_BASE=your-realtime-secret-key-base-at-least-64-characters-long-for-phoenix

# Supavisor Secret - Used for connection pooler
# Generate using: openssl rand -base64 48
SUPAVISOR_SECRET_KEY_BASE=your-supavisor-secret-key-base-at-least-64-characters-long

# Vault Encryption Key - For Supabase Vault secrets (32 chars)
VAULT_ENC_KEY=supabase-vault-encryption-key-xxxxx

# Realtime DB Encryption Key
REALTIME_DB_ENC_KEY=supabaserealtime

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

POSTGRES_USER=supabase_admin
POSTGRES_PASSWORD=your-super-secret-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# PostgreSQL connection string for direct access
# Used by backend services that need direct DB access
DATABASE_URL=postgresql+asyncpg://supabase_admin:your-super-secret-password@localhost:5432/postgres

# =============================================================================
# JWT CONFIGURATION
# =============================================================================

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY=3600

# =============================================================================
# API GATEWAY (KONG)
# =============================================================================

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# External API URL - How clients access the API
# For production, use your domain: https://api.your-domain.com
API_EXTERNAL_URL=http://localhost:8000

# =============================================================================
# SITE CONFIGURATION
# =============================================================================

# Frontend URL - Used for redirects, CORS, etc.
SITE_URL=http://localhost:3000

# Additional redirect URLs (comma-separated)
# For OAuth callbacks, email verification, etc.
ADDITIONAL_REDIRECT_URLS=

# =============================================================================
# AUTHENTICATION (GOTRUE)
# =============================================================================

# Disable user signup (invite-only mode)
DISABLE_SIGNUP=false

# Email authentication
ENABLE_EMAIL_SIGNUP=true
ENABLE_PHONE_AUTH=false

# OAuth providers (configure credentials below)
ENABLE_GITHUB_AUTH=false
ENABLE_GOOGLE_AUTH=false

# GitHub OAuth (if enabled)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (if enabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MFA/2FA
ENABLE_MFA=true

# Captcha (optional)
ENABLE_CAPTCHA=false
CAPTCHA_PROVIDER=hcaptcha
CAPTCHA_SECRET=

# =============================================================================
# SMTP CONFIGURATION (Email)
# =============================================================================
# Required for: email verification, password reset, magic links
# For development, use Inbucket (included) or Mailtrap
# For production, use SendGrid, Postmark, AWS SES, etc.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@pilot-space.local
SMTP_SENDER_NAME=Pilot Space

# Auto-confirm emails (DEVELOPMENT ONLY)
# Set to true to skip email verification in development
MAILER_AUTOCONFIRM=false

# =============================================================================
# STORAGE
# =============================================================================

# Maximum file size in bytes (default: 50MB)
FILE_SIZE_LIMIT=52428800

# =============================================================================
# POSTGREST
# =============================================================================

# Database schemas exposed via REST API
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Maximum rows returned per request
PGRST_DB_MAX_ROWS=1000

# =============================================================================
# EDGE FUNCTIONS
# =============================================================================

# Verify JWT for function calls (recommended: true)
FUNCTIONS_VERIFY_JWT=true

# =============================================================================
# SUPAVISOR (Connection Pooler)
# =============================================================================

# Transaction mode port (recommended for serverless)
SUPAVISOR_PORT=15432
SUPAVISOR_TRANSACTION_PORT=6543

# =============================================================================
# STUDIO (Admin Dashboard)
# =============================================================================

STUDIO_PORT=54323
STUDIO_DEFAULT_ORGANIZATION=Pilot Space
STUDIO_DEFAULT_PROJECT=pilot-space

# =============================================================================
# ANALYTICS (Logflare)
# =============================================================================

LOGFLARE_API_KEY=your-logflare-api-key

# =============================================================================
# REDIS (Caching Layer)
# =============================================================================
# Redis is kept for:
# - AI response caching
# - Session management
# - Rate limiting

REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_MEMORY=256mb

# =============================================================================
# MEILISEARCH (Full-Text Search)
# =============================================================================
# Meilisearch is kept for:
# - Typo-tolerant search
# - Faceted search
# - Instant search UX

MEILISEARCH_PORT=7700
MEILISEARCH_API_KEY=your-meilisearch-master-key
MEILI_ENV=development
MEILI_LOG_LEVEL=INFO
MEILI_MAX_INDEXING_MEMORY=512Mb
MEILI_MAX_INDEXING_THREADS=2

# =============================================================================
# AI PROVIDERS (BYOK - Bring Your Own Key)
# =============================================================================
# These keys are for development/testing only.
# In production, users configure their own keys per workspace.

# Anthropic (REQUIRED for AI code features)
ANTHROPIC_API_KEY=

# OpenAI (REQUIRED for embeddings/vector search)
OPENAI_API_KEY=

# Google AI (OPTIONAL - for latency-sensitive features)
GOOGLE_API_KEY=

# =============================================================================
# PILOT SPACE BACKEND CONFIGURATION
# =============================================================================

# FastAPI backend
BACKEND_PORT=8001
BACKEND_WORKERS=4

# AI behavior settings
AI_TIMEOUT_SECONDS=300
AI_MAX_RETRIES=3
AI_GHOST_TEXT_DEBOUNCE_MS=500
AI_GHOST_TEXT_MAX_TOKENS=50

# Rate limiting
RATE_LIMIT_STANDARD_PER_MINUTE=1000
RATE_LIMIT_AI_PER_MINUTE=100

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# PILOT SPACE FRONTEND CONFIGURATION
# =============================================================================

FRONTEND_PORT=3000

# Public API URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Supabase public configuration
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Feature flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_REALTIME=true

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify for production deployments:
#
# # Security
# MAILER_AUTOCONFIRM=false
# DISABLE_SIGNUP=true  # Invite-only
# ENABLE_MFA=true
#
# # Performance
# BACKEND_WORKERS=8
# REDIS_MAX_MEMORY=1gb
# MEILI_MAX_INDEXING_MEMORY=2048Mb
#
# # Logging
# MEILI_LOG_LEVEL=WARN
#
# # Use production domains
# API_EXTERNAL_URL=https://api.your-domain.com
# SITE_URL=https://app.your-domain.com
# CORS_ORIGINS=https://app.your-domain.com
