{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://pilot-space.io/schemas/export/v1.0.0",
  "title": "PilotSpaceExport",
  "description": "Schema for Pilot Space workspace data export format",
  "type": "object",
  "required": ["version", "exportedAt", "workspace"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for backward compatibility"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when export was created"
    },
    "exportedBy": {
      "type": "string",
      "format": "uuid",
      "description": "User ID who initiated the export"
    },
    "workspace": {
      "$ref": "#/definitions/Workspace"
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Project"
      },
      "default": []
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Issue"
      },
      "default": []
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Note"
      },
      "default": []
    },
    "cycles": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Cycle"
      },
      "default": []
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Module"
      },
      "default": []
    },
    "labels": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Label"
      },
      "default": []
    },
    "states": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/State"
      },
      "default": []
    },
    "templates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Template"
      },
      "default": []
    }
  },
  "definitions": {
    "Workspace": {
      "type": "object",
      "required": ["id", "name", "slug"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$"
        },
        "description": {
          "type": ["string", "null"]
        },
        "settings": {
          "type": "object",
          "additionalProperties": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Project": {
      "type": "object",
      "required": ["id", "workspaceId", "name", "identifier"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "identifier": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,10}$"
        },
        "description": {
          "type": ["string", "null"]
        },
        "emoji": {
          "type": ["string", "null"]
        },
        "coverImageUrl": {
          "type": ["string", "null"]
        },
        "settings": {
          "type": "object",
          "additionalProperties": true
        },
        "issueCounter": {
          "type": "integer",
          "minimum": 0
        },
        "isPublic": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Issue": {
      "type": "object",
      "required": ["id", "workspaceId", "projectId", "sequenceId", "name", "stateId", "reporterId"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "sequenceId": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "description": {
          "type": ["string", "null"]
        },
        "descriptionHtml": {
          "type": ["string", "null"]
        },
        "stateId": {
          "type": "string",
          "format": "uuid"
        },
        "priority": {
          "type": ["string", "null"],
          "enum": ["urgent", "high", "medium", "low", "none", null]
        },
        "startDate": {
          "type": ["string", "null"],
          "format": "date"
        },
        "targetDate": {
          "type": ["string", "null"],
          "format": "date"
        },
        "completedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "estimatePoints": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "assigneeId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "reporterId": {
          "type": "string",
          "format": "uuid"
        },
        "cycleId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "moduleId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "parentId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "sortOrder": {
          "type": "integer"
        },
        "labelIds": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "aiMetadata": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Note": {
      "type": "object",
      "required": ["id", "workspaceId", "title", "ownerId"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "content": {
          "type": "object",
          "description": "TipTap/ProseMirror JSON content"
        },
        "summary": {
          "type": ["string", "null"]
        },
        "wordCount": {
          "type": "integer",
          "minimum": 0
        },
        "readingTimeMins": {
          "type": "integer",
          "minimum": 0
        },
        "isPinned": {
          "type": "boolean"
        },
        "ownerId": {
          "type": "string",
          "format": "uuid"
        },
        "templateId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Cycle": {
      "type": "object",
      "required": ["id", "workspaceId", "projectId", "name", "startDate", "endDate"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "description": {
          "type": ["string", "null"]
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "endDate": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "completed", "cancelled"]
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "ownedById": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Module": {
      "type": "object",
      "required": ["id", "workspaceId", "projectId", "name"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "description": {
          "type": ["string", "null"]
        },
        "status": {
          "type": "string",
          "enum": ["planned", "active", "completed", "cancelled"]
        },
        "targetDate": {
          "type": ["string", "null"],
          "format": "date"
        },
        "sortOrder": {
          "type": "integer"
        },
        "leadId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Label": {
      "type": "object",
      "required": ["id", "workspaceId", "name", "color"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "description": {
          "type": ["string", "null"]
        },
        "parentId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "State": {
      "type": "object",
      "required": ["id", "projectId", "name", "group", "color"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "description": {
          "type": ["string", "null"]
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "group": {
          "type": "string",
          "enum": ["backlog", "unstarted", "started", "completed", "cancelled"]
        },
        "sortOrder": {
          "type": "integer"
        },
        "isDefault": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Template": {
      "type": "object",
      "required": ["id", "workspaceId", "name", "content", "templateType"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "workspaceId": {
          "type": "string",
          "format": "uuid"
        },
        "projectId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": ["string", "null"]
        },
        "emoji": {
          "type": ["string", "null"]
        },
        "content": {
          "type": "object",
          "description": "TipTap/ProseMirror JSON content"
        },
        "templateType": {
          "type": "string",
          "enum": ["note", "page", "issue_description"]
        },
        "sortOrder": {
          "type": "integer"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "additionalProperties": false
}
