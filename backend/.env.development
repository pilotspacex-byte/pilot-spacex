# Development Environment Configuration
# This file enables mock AI mode for local development without API keys

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=development
DEBUG=true
LOG_LEVEL=ERROR

# =============================================================================
# AI Mock Mode Configuration
# =============================================================================
# Enable fake AI responses (no external API calls)
AI_FAKE_MODE=true

# Simulated AI response latency in milliseconds (default: 500)
# Increase to simulate slower network conditions
AI_FAKE_LATENCY_MS=300

# Delay between streaming chunks in milliseconds (default: 50)
# Adjust to simulate different streaming speeds
AI_FAKE_STREAMING_CHUNK_DELAY_MS=30

# =============================================================================
# API Keys (NOT REQUIRED in mock mode)
# =============================================================================
# In mock mode, these keys are not used and can be left empty
ANTHROPIC_API_KEY=  # pragma: allowlist secret
OPENAI_API_KEY=  # pragma: allowlist secret
GOOGLE_API_KEY=  # pragma: allowlist secret

# =============================================================================
# Database Configuration
# =============================================================================
# Use local Supabase instance
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres  # pragma: allowlist secret
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# Supabase Configuration
# =============================================================================
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here  # pragma: allowlist secret
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long  # pragma: allowlist secret

# =============================================================================
# Meilisearch Configuration
# =============================================================================
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=1

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_STANDARD_PER_MINUTE=1000
RATE_LIMIT_AI_PER_MINUTE=100

# =============================================================================
# Security
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=

# =============================================================================
# GitHub Integration (Optional)
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/integrations/github/callback

# =============================================================================
# AI Timeouts and Retries
# =============================================================================
AI_TIMEOUT_SECONDS=300
AI_MAX_RETRIES=3
AI_GHOST_TEXT_DEBOUNCE_MS=500
AI_GHOST_TEXT_MAX_TOKENS=50
