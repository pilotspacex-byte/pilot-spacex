# =============================================================================
# Pilot Space Backend - Docker Ignore
# =============================================================================
# Exclude files and directories from Docker build context
# Reduces build time and prevents sensitive data from being included in images
# =============================================================================

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Type checker cache
.mypy_cache/
.pyright/
.ruff_cache/

# Pytest cache
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
test_*.py
*_test.py
conftest.py
pytest.ini
.coveragerc

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/
*.md
!README.md
LICENSE

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.secrets.baseline

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.circleci/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
docker-compose*.yaml
.docker/
.dockerignore

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
Makefile
*.sh
!entrypoint.sh
.pre-commit-config.yaml
.editorconfig
pyrightconfig.json
ruff.toml
setup.cfg

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.log
*.bak

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.ipynb
notebooks/
data/
*.sqlite
*.db
