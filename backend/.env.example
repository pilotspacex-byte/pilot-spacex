# Pilot Space Backend Environment Configuration
# Copy to .env and fill in values

# Application
APP_NAME=Pilot Space
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-key

# AI Providers (BYOK - optional at app level)
# These can be configured per-workspace in the application
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# AI Configuration
AI_TIMEOUT_SECONDS=300
AI_MAX_RETRIES=3
AI_GHOST_TEXT_DEBOUNCE_MS=500
AI_GHOST_TEXT_MAX_TOKENS=50

# Fake AI Mode (development only - no external API calls)
# Enable for local development without API costs
AI_FAKE_MODE=false
AI_FAKE_LATENCY_MS=500
AI_FAKE_STREAMING_CHUNK_DELAY_MS=50

# Rate Limiting
RATE_LIMIT_STANDARD_PER_MINUTE=1000
RATE_LIMIT_AI_PER_MINUTE=100

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# SAML 2.0 SSO (AUTH-01)
# Service Provider entity ID
SAML_SP_ENTITY_ID=https://app.pilotspace.dev/api/v1/auth/sso/saml/metadata
# SP private key in PEM format (base64-encoded single line recommended)
SAML_SP_PRIVATE_KEY=
# SP certificate in PEM format
SAML_SP_CERT_PEM=
# Backend base URL (used for SAML ACS/metadata URL construction)
BACKEND_URL=http://localhost:8000
