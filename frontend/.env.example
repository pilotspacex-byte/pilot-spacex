# ============================================================================
# Pilot Space Frontend - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the appropriate values.
# Never commit .env.local to version control!
# ============================================================================

# ============================================================================
# SUPABASE (REQUIRED)
# ============================================================================
# Run `supabase start` locally to get these values
# For production, get from https://supabase.com/dashboard/project/_/settings/api

# Supabase API URL
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Supabase Anonymous Key (safe to expose - RLS enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# BACKEND API (REQUIRED)
# ============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ============================================================================
# Internal Mode (Optional)
# ============================================================================
# Set to true to switch to internal mode, which may disable some features
NEXT_PUBLIC_INTERNAL_MODE=true
