# =============================================================================
# Docker Ignore - Pilot Space Frontend
# =============================================================================
# Excludes files from Docker build context for faster builds and smaller images
# =============================================================================

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Dependencies (will be installed fresh in container)
# -----------------------------------------------------------------------------
node_modules
.pnpm-store

# -----------------------------------------------------------------------------
# Build Outputs (will be built fresh in container)
# -----------------------------------------------------------------------------
.next
out
build
dist

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
coverage
.nyc_output
*.lcov
test-results
playwright-report
playwright/.cache

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# Documentation & Metadata
# -----------------------------------------------------------------------------
*.md
!README.md
LICENSE
CHANGELOG*
docs

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*
.docker

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.circleci

# -----------------------------------------------------------------------------
# Logs & Debug
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# TypeScript Build Info (not needed for Docker build)
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Storybook (if used)
# -----------------------------------------------------------------------------
storybook-static

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp
temp
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Analysis & Profiling
# -----------------------------------------------------------------------------
.analyze
*.cpuprofile
*.heapprofile
