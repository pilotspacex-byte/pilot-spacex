// ============================================================================
// Example 7: Programmatic Skill Invocation
// ============================================================================

function ProgrammaticSkillInvocation() {
  const mockStore = {} as IPilotSpaceStore;

  const handleExtractIssues = async () => {
    // Set the skill and send message
    mockStore.setActiveSkill('extract-issues');
    await mockStore.sendMessage('\\extract-issues from the current selection');
  };

  const handleImproveWriting = async (text: string) => {
    await mockStore.sendMessage(`\\improve-writing ${text}`);
  };

  return (
    <div className="space-y-4">
      <Button onClick={handleExtractIssues}>Extract Issues</Button>
      <Button onClick={() => handleImproveWriting('This text needs improvement')}>
        Improve Writing
      </Button>

      <ChatView store={mockStore} />
    </div>
  );
}

// ============================================================================
// Example 8: With Approval Handling
// ============================================================================

const ChatWithApprovals = observer(() => {
  const mockStore = {} as IPilotSpaceStore;

  // Approvals are automatically handled by ApprovalOverlay
  // No additional code needed - the overlay will appear when approvals are pending

  return <ChatView store={mockStore} />;
});

export {
  BasicExample,
  NoteEditorIntegration,
  IssueDetailIntegration,
  FullScreenChat,
  PopoverChat,
  ChatWithStore,
  ProgrammaticSkillInvocation,
  ChatWithApprovals,
};
